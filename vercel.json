{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "framework": "nodejs",
  "functions": {
    "server.js": {
      "runtime": "nodejs18.x"
    }
  },
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "routes": [
    {
      "src": "^/api-config.js$",
      "dest": "/api-config.js"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ]
}
